{
  "name": "myportfolio",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "overrides": {
    "hono": "^4.12.25",
    "@hono/node-server": "^1.19.13",
    "postcss": "$postcss",
    "vite": "^7.3.5",
    "rollup": "^4.59.1",
    "flatted": "^3.4.2",
    "defu": "^6.1.6",
    "fast-xml-parser": "^5.5.7",
    "picomatch": "^4.0.4",
    "dompurify": "^3.4.9",
    "js-yaml": "^4.2.0",
    "@babel/core": "^7.29.6",
    "lodash": "^4.18.1",
    "effect": "^3.21.1",
    "jspdf": "^4.2.1",
    "ajv": "^6.14.0",
    "minimatch": "^9.0.7",
    "brace-expansion": "^2.0.3",
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.7"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "sync:resume": "npx tsx scripts/sync-resume-skills.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "update": "bash scripts/update.sh",
    "setup": "bash scripts/setup-hooks.sh",
    "api:dev": "npm run dev --workspace @portfolio/api",
    "api:docker:build": "docker build -f apps/api/Dockerfile -t portfolio-api .",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@marsidev/react-turnstile": "^1.4.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/papaparse": "^5.5.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "html2pdf.js": "^0.14.0",
    "isomorphic-dompurify": "^2.35.0",
    "jose": "^6.1.3",
    "next": "^16.2.3",
    "nodemailer": "^9.0.1",
    "papaparse": "^5.5.3",
    "pg": "^8.16.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1",
    "together-ai": "^0.33.0",
    "unpdf": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@prisma/client": "^7.7.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.3",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.10",
    "prisma": "^7.7.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.6",
    "wrangler": "^4.102.0"
  }
}
